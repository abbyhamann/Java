package comHamann;
import java.awt.GridBagConstraints;
import java.awt.GridBagLayout;
import java.awt.Insets;
import java.awt.event.ActionEvent;
import java.awt.event.ActionListener;
import java.text.NumberFormat;
import javax.swing.JButton;
import javax.swing.JFormattedTextField;
import javax.swing.JFrame;
import javax.swing.JLabel;
import javax.swing.JOptionPane;
import javax.swing.JTextField;

public class FeePayment  extends JFrame implements ActionListener{
	JLabel feeLabel = null;
	JLabel deadlineLabel = null;
	JTextField feeField = null;
	JTextField deadlineField = null;
	JButton submitButton = null;
	JLabel endMessage = null;
	GridBagConstraints layoutConst = null;
	
	FeePayment() {
	
		feeLabel = new JLabel("Enter the fee to be paid:");
		deadlineLabel = new JLabel("Are you paying before the deadline?");
		
		endMessage = new JLabel();

		
		feeField = new JTextField(15);
		feeField.setEditable(true);
		
		deadlineField = new JTextField(15);
		deadlineField.setEditable(true);
		
		submitButton = new JButton("Submit");
		submitButton.addActionListener(this);
		
		setLayout(new GridBagLayout());
		
		layoutConst = new GridBagConstraints();
		layoutConst.insets = new Insets(10, 10, 10, 1);
		layoutConst.gridx = 0;
		layoutConst.gridy = 0;
		add(feeLabel, layoutConst);
		
		layoutConst = new GridBagConstraints();
		layoutConst.insets = new Insets(10, 1, 10, 10);
		layoutConst.gridx = 1;
		layoutConst.gridy = 0;
		add(feeField, layoutConst);
		
		layoutConst = new GridBagConstraints();
		layoutConst.insets = new Insets(10, 5, 10, 10);
		layoutConst.gridx = 0;
		layoutConst.gridy = 1;
		add(deadlineLabel, layoutConst);
		
		layoutConst = new GridBagConstraints();
		layoutConst.insets = new Insets(10, 0, 1, 10);
		layoutConst.gridx = 1;
		layoutConst.gridy = 1;
		add(deadlineField, layoutConst);
		
		layoutConst = new GridBagConstraints();
		layoutConst.insets = new Insets(1, 0, 10, 10);
		layoutConst.gridx = 1;
		layoutConst.gridy = 2;
		add(submitButton, layoutConst);
		
		layoutConst = new GridBagConstraints();
		layoutConst.insets = new Insets(10, 0, 1, 10);
		layoutConst.gridx = 1;
		layoutConst.gridy = 3;
		add(endMessage, layoutConst);
	}
	public void actionPerformed(ActionEvent event) {
		String deadline;
		
		deadline = (String) deadlineField.getText();
		
		if (deadline.equals("yes")) {
			endMessage.setText("Congratulations, your payment is done!");
			
		}
		else if (deadline.equals("no")) {
			endMessage.setText("Please pay $10 as a fine along with your school fee!");
		
		}
	}
	public static void main(String[] args) {
		FeePayment myFrame = new FeePayment();
		
		myFrame.setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
		myFrame.pack();
		myFrame.setVisible(true);
		
		

	}

}
